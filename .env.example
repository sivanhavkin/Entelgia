# Entelgia Production Configuration

# Memory Security
MEMORY_SECRET_KEY=your-secret-key-here-change-in-production-32-chars-min

# Grok (xAI) API Key (required when llm_backend = "grok" in Config)
# Get your API key from https://x.ai
GROK_API_KEY=

# Logging
LOG_LEVEL=INFO

# Database
DB_PATH=entelgia_data/entelgia_memory.sqlite

# Sessions
SESSIONS_DIR=entelgia_data/sessions

# API
API_HOST=0.0.0.0
API_PORT=8000
