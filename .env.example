# Entelgia Production Configuration

# Memory Security
MEMORY_SECRET_KEY=your-secret-key-here-change-in-production-32-chars-min

# ---------------------------------------------------------------------------
# Grok (xAI) Configuration
# Required only when using the Grok LLM backend.
#
# Only the API key goes here. The endpoint URL and model are set in the
# Config class (Entelgia_production_meta.py), not via environment variables.
#
# How to get a Grok API key:
#   1. Visit https://console.x.ai and sign in with your X (Twitter) account.
#   2. In the left sidebar click "API Keys".
#   3. Click "Create API Key", give it a name, and copy the generated key.
#   4. Paste the key as the value of GROK_API_KEY below.
# ---------------------------------------------------------------------------
GROK_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI Configuration
# Required only when using the OpenAI LLM backend.
#
# Only the API key goes here. The endpoint URL and model are set in the
# Config class (Entelgia_production_meta.py), not via environment variables.
#
# How to get an OpenAI API key:
#   1. Visit https://platform.openai.com and sign in.
#   2. In the left sidebar click "API keys".
#   3. Click "Create new secret key", give it a name, and copy the key.
#   4. Paste the key as the value of OPENAI_API_KEY below.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic Configuration
# Required only when using the Anthropic LLM backend.
#
# Only the API key goes here. The endpoint URL and model are set in the
# Config class (Entelgia_production_meta.py), not via environment variables.
#
# Available models (selected at Entelgia startup):
#   - claude-3-7-sonnet-latest
#   - claude-3-5-sonnet-latest
#   - claude-3-5-haiku-latest
#
# How to get an Anthropic API key:
#   1. Visit https://console.anthropic.com and sign in.
#   2. In the left sidebar click "API Keys".
#   3. Click "Create Key", give it a name, and copy the generated key.
#   4. Paste the key as the value of ANTHROPIC_API_KEY below.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=


LOG_LEVEL=INFO

# Database
DB_PATH=entelgia_data/entelgia_memory.sqlite

# Sessions
SESSIONS_DIR=entelgia_data/sessions

# API
API_HOST=0.0.0.0
API_PORT=8000
