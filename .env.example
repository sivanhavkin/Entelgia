# Entelgia Production Configuration

# Memory Security
MEMORY_SECRET_KEY=your-secret-key-here-change-in-production-32-chars-min

# Ollama LLM Configuration
OLLAMA_URL=http://localhost:11434/api/generate

# Logging
LOG_LEVEL=INFO

# Database
DB_PATH=entelgia_data/entelgia_memory.sqlite

# Sessions
SESSIONS_DIR=entelgia_data/sessions

# API
API_HOST=0.0.0.0
API_PORT=8000

# Timeout (minutes)
TIMEOUT_MINUTES=30

# Cache
CACHE_SIZE=5000

# LLM Models
# Set MODEL_SOCRATES and MODEL_ATHENA to your installed Ollama model (e.g. qwen2.5:7b).
# MODEL_FIXY is optional — if omitted or left empty it automatically inherits MODEL_SOCRATES.
MODEL_SOCRATES=phi3:latest
MODEL_ATHENA=phi3:latest
# MODEL_FIXY=phi3:latest  # uncomment only to override with a different model for Fixy
