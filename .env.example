# Entelgia Production Configuration

# Memory Security
MEMORY_SECRET_KEY=your-secret-key-here-change-in-production-32-chars-min

# ---------------------------------------------------------------------------
# LLM Backend Selection
# Set to "ollama" to use a local Ollama model (default, no API key required)
# Set to "grok"   to use xAI's Grok API (requires GROK_API_KEY below)
# ---------------------------------------------------------------------------
LLM_BACKEND=ollama

# ---------------------------------------------------------------------------
# Grok (xAI) Configuration
# Required only when LLM_BACKEND=grok
#
# How to get a Grok API key:
#   1. Visit https://console.x.ai and sign in with your X (Twitter) account.
#   2. In the left sidebar click "API Keys".
#   3. Click "Create API Key", give it a name, and copy the generated key.
#   4. Paste the key as the value of GROK_API_KEY below.
#   5. Make sure to set LLM_BACKEND=grok above.
#
# Available Grok models (set inside Config in the main script):
#   grok-3, grok-3-fast, grok-3-mini, grok-3-mini-fast, grok-2-1212
# ---------------------------------------------------------------------------
GROK_API_KEY=
GROK_URL=https://api.x.ai/v1/responses

# Logging
LOG_LEVEL=INFO

# Database
DB_PATH=entelgia_data/entelgia_memory.sqlite

# Sessions
SESSIONS_DIR=entelgia_data/sessions

# API
API_HOST=0.0.0.0
API_PORT=8000
