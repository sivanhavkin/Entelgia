# Entelgia Production Configuration

# Memory Security
MEMORY_SECRET_KEY=your-secret-key-here-change-in-production-32-chars-min

# LLM Backend Selection: "ollama" (local, default) or "grok" (xAI cloud)
LLM_BACKEND=ollama

# Ollama LLM Configuration (used when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434/api/generate

# Grok (xAI) LLM Configuration (used when LLM_BACKEND=grok)
# Get your API key from https://x.ai
GROK_API_KEY=
GROK_URL=https://api.x.ai/v1/chat/completions

# Logging
LOG_LEVEL=INFO

# Database
DB_PATH=entelgia_data/entelgia_memory.sqlite

# Sessions
SESSIONS_DIR=entelgia_data/sessions

# API
API_HOST=0.0.0.0
API_PORT=8000

# Timeout (minutes)
TIMEOUT_MINUTES=30

# Cache
CACHE_SIZE=5000

# LLM Models
# For Ollama: qwen2.5:7b, llama3.1:8b, mistral:latest, etc.
# For Grok:   grok-3, grok-3-mini, grok-3-fast, etc.
MODEL_SOCRATES=qwen2.5:7b
MODEL_ATHENA=qwen2.5:7b
MODEL_FIXY=qwen2.5:7b
